const GRID_OFFSET: int = 0x001F0000;

var cursor_x: int = 0;
var cursor_y: int = 0;
var current_color: int = 0xFF;

void _start() {
	var string: *char = &"Hello, World!\n";

	puts(string);
	while 1 {}
}

void advance_cursor() {
	cursor_x += 1;
	if cursor_x < 80 {
		return;
	}
	cursor_y += 1;
	cursor_x = 0;
	if cursor_y < 25 {
		return;
	}
	cursor_y = 0;
}

void putc(char c) {
	var off: *char = GRID_OFFSET + (cursor_x + cursor_y * 80) * 2;
	*off = c;
	*(off + 1) = current_color;
}

void puts(*char c) {
	while *c {
		putc(*c);
		c += 1;
	}
}
